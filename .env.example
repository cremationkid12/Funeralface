# Mobile app environment
APP_ENV=development

# Backend API
API_BASE_URL=http://localhost:8010

# Deep link host (verified domain in production)
DEEPLINK_HOST=links.example.com

# Base URL for family status links (staff copy); default matches Android App Links host
FAMILY_LINK_BASE=https://everroutefuneral.com

# Optional Supabase client values (if direct client usage is added)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
